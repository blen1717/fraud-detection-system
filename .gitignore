## 📄 .gitignore

`gitignore
# Data files (large, sensitive)
data/raw/
*.csv

# Processed data (can be regenerated)
data/processed/

# Python cache
pycache/
*.pyc
*.pyo
*.pyd

# Jupyter notebook checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# Virtual environments
venv/
env/
.venv

# IDE / OS files
.DS_Store
.vscode/
.idea/

# Logs and temporary files
*.log
*.tmp

# Model binaries (optional – can be regenerated)
models/*.pkl

# SHAP plots (optional – keep them if you want, but not required)
# reports/*.png
